DATABASE_URL=postgresql://sms:sms@localhost:5432/sms_dev

# JWT signing secrets — the values below are PLACEHOLDERS for local dev only.
# In production these MUST be long, random, and distinct from each other,
# e.g. generate each with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Never reuse the access secret as the refresh secret, and never commit real values.
JWT_ACCESS_SECRET=CHANGE_ME__dev_placeholder_access_secret
JWT_REFRESH_SECRET=CHANGE_ME__dev_placeholder_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Not needed until Phase 4 (Fees & MoMo)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Not needed until Phase 5 (Communications)
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=

NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NODE_ENV=development
PORT=3001

# Browser origin(s) of the web app, comma-separated, for CORS.
# localhost:3000 is always allowed in addition to these.
WEB_ORIGIN=

# Set to 1 only when running behind a hosting proxy/load balancer
# (Render, Railway, etc.) so per-IP rate limiting sees real client IPs.
TRUST_PROXY=
